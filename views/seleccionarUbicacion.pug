extends __layout/main

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-6.col-lg-5

        .card.shadow-lg
          .card-header.bg-primary.text-white.text-center.py-3
            i.bi.bi-geo-alt-fill.me-2(style='font-size:1.5rem')
            strong Seleccionar Ubicación de Trabajo

          .card-body.p-4
            p.text-muted.mb-4 Estás asignado a más de una ubicación. Seleccioná en cuál vas a trabajar hoy:

            .d-flex.flex-column.gap-3#listaUbicaciones
              each ubi in ubicaciones
                .card.border.rounded-3.ubicacion-card(
                  data-id=ubi.id
                  style='cursor:pointer; transition: all 0.15s;'
                )
                  .card-body.py-3.d-flex.align-items-center
                    input.form-check-input.me-3.flex-shrink-0(
                      type='radio'
                      name='id_ubicacion'
                      value=ubi.id
                      id=`ubi_${ubi.id}`
                    )
                    label.form-check-label.mb-0(
                      for=`ubi_${ubi.id}`
                      style='cursor:pointer'
                    )
                      i.bi.bi-hospital.me-2.text-primary
                      = ubi.nombre

            .d-grid.mt-4
              button.btn.btn-primary.btn-lg(type='button' id='btnConfirmar' disabled)
                i.bi.bi-check-circle.me-2
                | Confirmar Ubicación

  script(src='/js/login/seleccionarUbicacion.js')
