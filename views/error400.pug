extends __layout/main

block content
  .container.mt-5.text-center
    .row.justify-content-center
      .col-md-6
        .card.border-warning.shadow
          .card-body.py-5
            i.bi.bi-exclamation-circle.text-warning(style='font-size: 4rem')
            h1.display-4.mt-3 400
            h4.text-warning.mb-3 Solicitud incorrecta
            p.text-muted
              | Los datos enviados no son válidos o están incompletos.
              br
              | Revisá el formulario e intentá nuevamente.
            hr
            a.btn.btn-primary(href='/dashboard')
              i.bi.bi-house.me-2
              | Volver al inicio
