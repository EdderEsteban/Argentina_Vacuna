extends __layout/main

block content
  .container
    .row.justify-content-center
      .col-md-5
        .card.shadow
          .card-header.bg-primary.text-white.text-center
            i.bi.bi-shield-lock.me-2(style='font-size:1.4rem')
            strong Iniciar Sesión
          .card-body.p-4
            form#loginForm
              input(type="hidden" name="_csrf" value=csrfToken)
              .form-floating.mb-3
                input.form-control#usuario(
                  type="text"
                  name="usuario"
                  autocomplete="username"
                  placeholder="Usuario"
                  required
                )
                label(for="usuario") Usuario
              .form-floating.mb-3
                input.form-control#password(
                  type="password"
                  name="password"
                  autocomplete="current-password"
                  placeholder="Contraseña"
                  required
                )
                label(for="password") Contraseña
              .d-grid
                button#iniciarSesion.btn.btn-primary(type="button")
                  i.bi.bi-box-arrow-in-right.me-2
                  | Iniciar Sesión
          .card-footer.text-center.text-muted.small
            | ¿No tenés cuenta?
            a#solicitud.btn.btn-link.btn-sm.p-0.ms-1(href="/solicitud") Solicitar Acceso

  script(src="/js/login/index.js")
