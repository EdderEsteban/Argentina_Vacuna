extends ../__layout/main

block content
    .container.mt-4
        h1.mb-4 ✏️ Editar Paciente

        form#formEditarPaciente
            input(type="hidden" name="_csrf" value=csrfToken)
            input(type="hidden" id="pacienteId" value=paciente.id)

            .form-floating.mb-3 
                input.form-control(
                    type="text"
                    id="nombrePaciente"
                    name="nombrePaciente"
                    required
                    autofocus
                    minlength="2"
                    maxlength="100"
                    value=paciente.nombre
                )
                label.form-label(for="nombrePaciente") Nombre
                small.form-text.text-muted Mínimo 2 caracteres, máximo 100

            .form-floating.mb-3
                input.form-control(
                    type="text"
                    id="apellidoPaciente"
                    name="apellidoPaciente"
                    required
                    minlength="2"
                    maxlength="100"
                    value=paciente.apellido
                )
                label.form-label(for="apellidoPaciente") Apellido
                small.form-text.text-muted Mínimo 2 caracteres, máximo 100

            .form-floating.mb-3
                input.form-control(
                    type="text"
                    id="dniPaciente"
                    name="dniPaciente"
                    required
                    minlength="7"
                    maxlength="8"
                    value=paciente.dni
                )
                label.form-label(for="dniPaciente") DNI

            .form-floating.mb-3
                input.form-control(
                    type="date"
                    id="fecha_nacimiento"
                    name="fecha_nacimiento"
                    value=paciente.fecha_nacimiento || ''
                    placeholder=""
                )
                label.form-label(for="fecha_nacimiento") Fecha de Nacimiento

            .form-floating.mb-3
                select.form-select(
                    id="genero"
                    name="genero"
                )
                    option(value="" disabled) -- Seleccionar Género --
                    option(value="Masculino" selected=paciente.genero === 'Masculino') Masculino
                    option(value="Femenino" selected=paciente.genero === 'Femenino') Femenino
                    option(value="No binario" selected=paciente.genero === 'No binario') No binario
                    option(value="Prefiero no decir" selected=paciente.genero === 'Prefiero no decir') Prefiero no decir
                label.form-label(for="genero") Género

            .form-floating.mb-3
                input.form-control(
                    type="text"
                    id="localidad"
                    name="localidad"
                    value=paciente.localidad || ''
                    placeholder=""
                    maxlength="255"
                )
                label.form-label(for="localidad") Localidad

            .form-floating.mb-3
                input.form-control(
                    type="tel"
                    id="telefonoPaciente"
                    name="telefonoPaciente"
                    value=paciente.telefono || ''
                )
                label.form-label(for="telefonoPaciente") Teléfono

            .form-floating.mb-3
                input.form-control(
                    type="email"
                    id="correoPaciente"
                    name="correoPaciente"
                    value=paciente.correo || ''
                )
                label.form-label(for="correoPaciente") Correo Electrónico

            .form-floating.mb-3
                select.form-select(
                    id="id_provincia"
                    name="id_provincia"
                    required
                    value=paciente.id_provincia
                )
                    option(value="" disabled) -- Seleccionar Provincia --
                    each provincia in provincias
                        option(value=provincia.id, selected=provincia.id == paciente.id_provincia)= provincia.nombre
                label.form-label(for="id_provincia") Provincia

            .form-floating.mb-3
                select.form-select(
                    id="ubicacionRegistroPaciente"
                    name="ubicacionRegistroPaciente"
                    required
                    value=paciente.id_ubicacion_registro
                )
                    option(value="" disabled) -- Seleccionar Centro de Salud --
                    each ubicacion in ubicaciones
                        option(value=ubicacion.id, selected=ubicacion.id == paciente.id_ubicacion_registro)= ubicacion.nombre
                label.form-label(for="ubicacionRegistroPaciente") Centro de Salud

            .d-flex.gap-2
                button.btn.btn-primary.mb-3(type="button" id="guardarCambiosPaciente")
                    i.bi.bi-save.me-2
                    | Guardar Cambios
                a.btn.btn-secondary.mb-3(type="button" id="cancelarEdicionPaciente")
                    i.bi.bi-x-circle.me-2
                    | Cancelar

    script(src="/js/paciente/modificarPaciente.js")

    script.
        $(document).ready(function() {
          function inicializarSelect2(selector) {
            $(selector).select2({
              placeholder: '',
              allowClear: true,
              width: '100%',
              dropdownParent: $(selector).parent()
            });
          }

          inicializarSelect2('#id_provincia');
          inicializarSelect2('#ubicacionRegistroPaciente');
        });