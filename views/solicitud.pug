extends __layout/main

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-8
        .card.shadow
          .card-header.bg-info.text-white.py-3
            h4.mb-0
              i.bi.bi-person-plus.me-2
              | Solicitud de Acceso al Sistema
          .card-body.p-4
            p.text-muted.small.mb-4
              i.bi.bi-info-circle.me-1
              | Completá el formulario con tus datos. Tu solicitud será revisada por un administrador.

            form#formSolicitud
              input(type="hidden" name="_csrf" value=csrfToken)
              .row.g-3

                .col-md-6
                  .form-floating
                    input.form-control#nombre(type="text" name="nombre" placeholder="" maxlength="100")
                    label(for="nombre") Nombre *

                .col-md-6
                  .form-floating
                    input.form-control#apellido(type="text" name="apellido" placeholder="" maxlength="100")
                    label(for="apellido") Apellido *

                .col-md-6
                  .form-floating
                    input.form-control#dni(type="text" name="dni" placeholder="" maxlength="8")
                    label(for="dni") DNI *

                .col-md-6
                  .form-floating
                    input.form-control#usuario(type="text" name="usuario" placeholder="" maxlength="50" autocomplete="username")
                    label(for="usuario") Nombre de usuario *
                  .form-text.ms-1.small.text-muted Sin espacios · entre 4 y 50 caracteres

                .col-md-6
                  .form-floating
                    input.form-control#password(type="password" name="password" placeholder="" autocomplete="new-password")
                    label(for="password") Contraseña *
                  .form-text.ms-1.small.text-muted Mínimo 8 caracteres

                .col-md-6
                  .form-floating
                    input.form-control#confirmPassword(type="password" placeholder="" autocomplete="new-password")
                    label(for="confirmPassword") Confirmar Contraseña *

                .col-md-6
                  .form-floating
                    input.form-control#correo(type="email" name="correo" placeholder="")
                    label(for="correo") Correo Electrónico *

                .col-md-6
                  .form-floating
                    input.form-control#telefono(type="text" name="telefono" placeholder="")
                    label(for="telefono") Teléfono *

                .col-12
                  .form-floating
                    textarea.form-control#motivo(name="motivo" placeholder="" style="height:100px")
                    label(for="motivo") Motivo / Rol solicitado *
                  .form-text.ms-1.small.text-muted Describí tu función y por qué necesitás acceso (mínimo 10 caracteres).

              .d-grid.mt-4
                button.btn.btn-primary.btn-lg#btnEnviarSolicitud(type="submit")
                  i.bi.bi-send.me-2
                  | Enviar Solicitud

  script(src="/js/login/solicitud.js")
