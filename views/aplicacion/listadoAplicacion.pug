extends ../__layout/main

block content
  .container.mt-4
    h1.mb-4 💉 Listado de Aplicaciones

    .d-flex.gap-2.mb-3
      a.btn.btn-primary(href='/nuevaaplicacion')
        i.bi.bi-plus-circle.me-2
        | Registrar Aplicación
      a.btn.btn-outline-secondary(href='/buscadoraplicacion')
        i.bi.bi-search.me-2
        | Buscar

    .table-responsive
      table.table.table-striped.table-hover.align-middle
        thead.table-dark
          tr
            th(scope='col') Fecha
            th(scope='col') Paciente
            th(scope='col') DNI
            th(scope='col') Lote
            th(scope='col') Tipo de Vacuna
            th(scope='col') Centro de Vacunación
            th(scope='col') Enfermero
        tbody
          if aplicaciones.length === 0
            tr
              td.text-center.text-muted(colspan='7') No hay aplicaciones registradas
          each a in aplicaciones
            tr
              td= a.fecha_aplicacion
              td= a.paciente ? `${a.paciente.nombre} ${a.paciente.apellido}` : '—'
              td= a.paciente ? a.paciente.dni : '—'
              td= a.lote ? a.lote.num_lote : '—'
              td= (a.lote && a.lote.vacunas && a.lote.vacunas.length > 0) ? a.lote.vacunas[0].tipo : '—'
              td= a.ubicacion ? a.ubicacion.nombre : '—'
              td= a.usuario ? `${a.usuario.nombre} ${a.usuario.apellido}` : '—'

    if pagination.totalPages > 1
      nav(aria-label='Paginación')
        ul.pagination.justify-content-center
          li.page-item(class=pagination.currentPage === 1 ? 'disabled' : '')
            a.page-link(href=`/aplicaciones?page=${pagination.currentPage - 1}`) &laquo;

          - let startPage = Math.max(1, pagination.currentPage - 2)
          - let endPage = Math.min(pagination.totalPages, pagination.currentPage + 2)

          if startPage > 1
            li.page-item
              a.page-link(href='/aplicaciones?page=1') 1
            li.page-item.disabled
              span.page-link ...
          each pageNum in Array(endPage - startPage + 1).fill().map((_, i) => startPage + i)
            li.page-item(class=pageNum === pagination.currentPage ? 'active' : '')
              a.page-link(href=`/aplicaciones?page=${pageNum}`)= pageNum
          if endPage < pagination.totalPages
            li.page-item.disabled
              span.page-link ...
            li.page-item
              a.page-link(href=`/aplicaciones?page=${pagination.totalPages}`)= pagination.totalPages
          li.page-item(class=pagination.currentPage === pagination.totalPages ? 'disabled' : '')
            a.page-link(href=`/aplicaciones?page=${pagination.currentPage + 1}`) &raquo;
