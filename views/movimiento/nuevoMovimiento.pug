extends ../__layout/main

block content
  .container.mt-4
    .d-flex.justify-content-between.align-items-center.mb-4
      h2.fw-bold
        i.bi.bi-arrow-left-right.me-2
        | Nuevo Movimiento de Lote
      a.btn.btn-outline-secondary(href="/movimientos")
        i.bi.bi-arrow-left.me-1
        | Volver

    .card.shadow-sm
      .card-body.p-4
        form#formMovimiento
          .row.g-3

            .col-md-6
              .form-floating
                select.form-select#id_lote(name="id_lote" required)
                  option(value="" disabled selected) Seleccione un lote
                  each lote in lotes
                    option(value=lote.id)= lote.num_lote
                label(for="id_lote") Lote *

            .col-md-6
              .form-floating
                input.form-control#cantidad(type="number" name="cantidad" min="1" placeholder="0" required)
                label(for="cantidad") Cantidad *

            .col-md-6
              .form-floating
                select.form-select#id_ubicacion_origen(name="id_ubicacion_origen")
                  option(value="") Depósito Nacional (sin origen)
                  each u in ubicaciones
                    option(value=u.id)= `${u.nombre} (${u.tipo})`
                label(for="id_ubicacion_origen") Ubicación Origen

            .col-md-6
              .form-floating
                select.form-select#id_ubicacion_destino(name="id_ubicacion_destino" required)
                  option(value="" disabled selected) Seleccione destino
                  each u in ubicaciones
                    option(value=u.id)= `${u.nombre} (${u.tipo})`
                label(for="id_ubicacion_destino") Ubicación Destino *

            .col-md-6
              .form-floating
                input.form-control#fecha_movimiento(type="date" name="fecha_movimiento" value=new Date().toISOString().split('T')[0] required)
                label(for="fecha_movimiento") Fecha de Movimiento *

          .d-flex.justify-content-end.gap-2.mt-4
            a.btn.btn-outline-secondary(href="/movimientos")
              i.bi.bi-x-circle.me-1
              | Cancelar
            button.btn.btn-primary#btnRegistrar(type="submit")
              i.bi.bi-check-circle.me-1
              | Registrar Movimiento

  script(src="/js/movimiento/nuevoMovimiento.js")
