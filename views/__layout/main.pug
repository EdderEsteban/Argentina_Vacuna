doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        meta(name="csrf-token" content=csrfToken)

        link(rel="icon" href="/img/favicon.ico")
        link(rel="stylesheet" href="/css/style.css")
        link(rel="stylesheet" href="/css/logo.css")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous")
        link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css')
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css")
        script(src="https://code.jquery.com/jquery-3.6.0.min.js")
        link(rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons")

        title Argentina Vacuna

    body.d-flex.flex-column.min-vh-100

        //- Navbar Bootstrap
        if usuario
          nav.navbar.navbar-expand-lg.navbar-dark.bg-primary.shadow-sm
            .container-fluid
              a.navbar-brand.fw-bold(href='/dashboard')
                i.bi.bi-shield-check.me-2
                | Argentina Vacuna
              button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarMain')
                span.navbar-toggler-icon

              #navbarMain.collapse.navbar-collapse
                //- Menú por rol
                ul.navbar-nav.me-auto.mb-2.mb-lg-0
                  if usuario.rol === 'Administrador'
                    li.nav-item.dropdown
                      a.nav-link.dropdown-toggle(href='#' data-bs-toggle='dropdown') Gestión
                      ul.dropdown-menu
                        li: a.dropdown-item(href='/laboratorios')
                          i.bi.bi-building.me-2
                          | Laboratorios
                        li: a.dropdown-item(href='/lotes')
                          i.bi.bi-box-seam.me-2
                          | Lotes
                        li: a.dropdown-item(href='/ubicaciones')
                          i.bi.bi-geo-alt.me-2
                          | Ubicaciones
                        li: a.dropdown-item(href='/movimientos')
                          i.bi.bi-arrow-left-right.me-2
                          | Movimientos
                        li: hr.dropdown-divider
                        li: a.dropdown-item(href='/usuarios')
                          i.bi.bi-people.me-2
                          | Usuarios
                        li: a.dropdown-item(href='/solicitudes')
                          i.bi.bi-person-check.me-2
                          | Solicitudes de Acceso
                    li.nav-item.dropdown
                      a.nav-link.dropdown-toggle(href='#' data-bs-toggle='dropdown') Registro
                      ul.dropdown-menu
                        li: a.dropdown-item(href='/pacientes')
                          i.bi.bi-person-badge.me-2
                          | Pacientes
                        li: a.dropdown-item(href='/aplicaciones')
                          i.bi.bi-capsule.me-2
                          | Aplicaciones
                        li: a.dropdown-item(href='/descartes')
                          i.bi.bi-trash.me-2
                          | Descartes
                    li.nav-item
                      a.nav-link(href='/reportes')
                        i.bi.bi-bar-chart-line.me-2
                        | Reportes

                  else if usuario.rol === 'Auditor'
                    li.nav-item.dropdown
                      a.nav-link.dropdown-toggle(href='#' data-bs-toggle='dropdown') Consultas
                      ul.dropdown-menu
                        li: a.dropdown-item(href='/laboratorios')
                          i.bi.bi-building.me-2
                          | Laboratorios
                        li: a.dropdown-item(href='/lotes')
                          i.bi.bi-box-seam.me-2
                          | Lotes
                        li: a.dropdown-item(href='/ubicaciones')
                          i.bi.bi-geo-alt.me-2
                          | Ubicaciones
                        li: a.dropdown-item(href='/movimientos')
                          i.bi.bi-arrow-left-right.me-2
                          | Movimientos
                        li: a.dropdown-item(href='/pacientes')
                          i.bi.bi-person-badge.me-2
                          | Pacientes
                        li: a.dropdown-item(href='/aplicaciones')
                          i.bi.bi-capsule.me-2
                          | Aplicaciones
                        li: a.dropdown-item(href='/descartes')
                          i.bi.bi-trash.me-2
                          | Descartes
                    li.nav-item
                      a.nav-link(href='/reportes')
                        i.bi.bi-bar-chart-line.me-2
                        | Reportes

                  else if usuario.rol === 'Enfermero'
                    li.nav-item
                      a.nav-link(href='/pacientes')
                        i.bi.bi-person-badge.me-2
                        | Pacientes
                    li.nav-item
                      a.nav-link(href='/aplicaciones')
                        i.bi.bi-capsule.me-2
                        | Aplicaciones
                    li.nav-item
                      a.nav-link(href='/lotes')
                        i.bi.bi-box-seam.me-2
                        | Lotes

                  else if usuario.rol === 'Administrativo'
                    li.nav-item
                      a.nav-link(href='/reportes')
                        i.bi.bi-bar-chart-line.me-2
                        | Reportes

                //- Usuario + logout
                ul.navbar-nav.ms-auto.align-items-center
                  li.nav-item.dropdown
                    a.nav-link.dropdown-toggle(href='#' data-bs-toggle='dropdown')
                      i.bi.bi-person-circle.me-1
                      | #{usuario.nombre} #{usuario.apellido}
                      span.badge.bg-light.text-primary.ms-2.small= usuario.rol
                      if usuario.ubicacionActual
                        span.badge.bg-light.text-success.ms-1.small
                          i.bi.bi-geo-alt.me-1
                          = usuario.ubicacionActual.nombre
                    ul.dropdown-menu.dropdown-menu-end
                      li
                        span.dropdown-item-text.text-muted.small
                          i.bi.bi-envelope.me-1
                          | #{usuario.usuario}
                      if usuario.ubicaciones && usuario.ubicaciones.length > 1
                        li: hr.dropdown-divider
                        li
                          a.dropdown-item(href='/seleccionar-ubicacion')
                            i.bi.bi-arrow-repeat.me-2
                            | Cambiar ubicación
                      li: hr.dropdown-divider
                      li
                        a.dropdown-item.text-danger(href='/logout')
                          i.bi.bi-box-arrow-right.me-2
                          | Cerrar sesión

        //- Logo flotante (solo cuando no hay sesión)
        else
          .logo-container
            a(href="/" title="Click para ir al Inicio")
              img.logo-flotante(src="/img/vacuna.png")

        //- Contenido principal
        main.flex-grow-1.pt-4
            block content

        include footer

        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous")
        script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")
        script(src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js")

        script.
            document.addEventListener('DOMContentLoaded', function() {
                const textareas = document.querySelectorAll('textarea');
                textareas.forEach(textarea => {
                    textarea.addEventListener('input', function() {
                        this.style.height = 'auto';
                        this.style.height = (this.scrollHeight) + 'px';
                    });
                });
            });
